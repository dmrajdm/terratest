region         = "us-east-1"
cluster_name   = "dev-eks"
cluster_version = "1.29"
vpc_id         = "vpc-xxxx"
subnet_ids     = ["subnet-a", "subnet-b"]
route53_zone_id = "Z123456789"

eks_managed_node_groups = {
  default = {
    min_size     = 1
    max_size     = 3
    desired_size = 1
    instance_types = ["t3.medium"]
  }
}

