region         = "us-east-1"
cluster_name   = "stage-eks"
cluster_version = "1.29"
vpc_id         = "vpc-yyyy"
subnet_ids     = ["subnet-a", "subnet-b"]
route53_zone_id = "Z987654321"

eks_managed_node_groups = {
  default = {
    min_size     = 2
    max_size     = 4
    desired_size = 2
    instance_types = ["t3.medium"]
  }
}

